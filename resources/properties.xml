<resources xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">

  <properties>
    <property id="ApiKey" type="string"></property>
    <property id="ApiUrl" type="string">https://api.garminbadges.com/api</property>
    <property id="MaxDurationDays" type="number">0</property>
  </properties>

  <strings>
    <string id="AppName">Badge Tracker</string>
    <string id="ApiKeyTitle">API Key</string>
    <string id="ApiUrlTitle">API URL</string>
    <string id="MaxDurationDaysTitle">Max Duration (days, 0 = no limit)</string>
  </strings>

  <settings>
    <setting propertyKey="@Properties.ApiKey" title="@Strings.ApiKeyTitle">
      <settingConfig type="alphaNumeric"/>
    </setting>
    <setting propertyKey="@Properties.ApiUrl" title="@Strings.ApiUrlTitle">
      <settingConfig type="alphaNumeric"/>
    </setting>
    <setting propertyKey="@Properties.MaxDurationDays" title="@Strings.MaxDurationDaysTitle">
      <settingConfig type="numeric" min="0" max="365"/>
    </setting>
  </settings>

</resources>
